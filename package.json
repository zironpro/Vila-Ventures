{
	"name": "vila-ventures",
	"version": "0.1.0",
	"description": "Ecommerce website for Vila Ventures",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
		"build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
		"start": "cross-env NODE_OPTIONS=--no-deprecation next start",
		"lint": "biome check",
		"format": "biome format --write",
		"payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
		"generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
		"generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
		"seed:class-plans": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-class-plans.ts",
		"migrate:class-plans": "tsx --env-file=.env scripts/migrate-class-plans-schema.ts",
		"reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
		"stripe-webhooks": "stripe listen --forward-to localhost:3000/api/payments/stripe/webhooks"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.0",
		"@hookform/resolvers": "^5.2.2",
		"@number-flow/react": "^0.6.0",
		"@openpanel/nextjs": "^1.5.0",
		"@payloadcms/admin-bar": "^3.84.1",
		"@payloadcms/db-postgres": "^3.84.1",
		"@payloadcms/db-sqlite": "3.84.1",
		"@payloadcms/email-nodemailer": "^3.84.1",
		"@payloadcms/live-preview-react": "^3.84.1",
		"@payloadcms/next": "3.84.1",
		"@payloadcms/plugin-ecommerce": "^3.84.1",
		"@payloadcms/plugin-form-builder": "^3.84.1",
		"@payloadcms/plugin-seo": "^3.84.1",
		"@payloadcms/richtext-lexical": "3.84.1",
		"@payloadcms/translations": "^3.84.1",
		"@payloadcms/ui": "^3.84.1",
		"@phosphor-icons/react": "^2.1.10",
		"@tanstack/react-form": "^1.29.1",
		"canvas-confetti": "^1.9.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cross-env": "^10.1.0",
		"embla-carousel-auto-scroll": "^8.6.0",
		"embla-carousel-autoplay": "^8.6.0",
		"embla-carousel-react": "^8.6.0",
		"graphql": "^16.13.2",
		"lenis": "^1.3.23",
		"motion": "^12.38.0",
		"next": "16.2.6",
		"next-themes": "^0.4.6",
		"payload": "3.84.1",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-fast-marquee": "^1.6.5",
		"react-hook-form": "^7.72.1",
		"schema-dts": "^2.0.0",
		"shadcn": "^4.3.0",
		"sharp": "^0.34.5",
		"sonner": "^2.0.7",
		"stripe": "^22.0.2",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@tailwindcss/postcss": "^4",
		"@tailwindcss/typography": "^0.5.19",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^20",
		"@types/pg": "^8.20.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"babel-plugin-react-compiler": "1.0.0",
		"pg": "^8.20.0",
		"tailwindcss": "^4",
		"tsx": "^4.22.1",
		"typescript": "^5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp",
			"esbuild",
			"msw"
		]
	}
}
